{
  "_comment": "Add this config to your Claude Desktop claude_desktop_config.json file",
  "_location_mac": "~/Library/Application Support/Claude/claude_desktop_config.json",
  "_location_win": "%APPDATA%\\Claude\\claude_desktop_config.json",

  "mcpServers": {
    "driveclone": {
      "command": "node",
      "args": ["/ABSOLUTE/PATH/TO/driveclone/backend/mcp/mcpServer.js"],
      "env": {
        "MONGO_URI": "your_mongodb_atlas_connection_string",
        "CLOUDINARY_CLOUD_NAME": "your_cloudinary_cloud_name",
        "CLOUDINARY_API_KEY": "your_cloudinary_api_key",
        "CLOUDINARY_API_SECRET": "your_cloudinary_api_secret",
        "MCP_PORT": "5001"
      }
    }
  }
}
